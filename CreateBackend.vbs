' VBScript to create backend directory structure for Canteras Renacimiento Admin Panel
' Save as: CreateBackend.vbs and run with: cscript.exe CreateBackend.vbs

Dim fso, basePath, dirs, i
Set fso = CreateObject("Scripting.FileSystemObject")

basePath = "c:\Users\Xavier\para proyectos web\proyecto\backend"

' Create directories
dirs = Array(basePath, basePath & "\config", basePath & "\middleware", basePath & "\routes")

For i = 0 To UBound(dirs)
    If Not fso.FolderExists(dirs(i)) Then
        fso.CreateFolder(dirs(i))
        WScript.Echo "Created: " & dirs(i)
    End If
Next

' Create .gitignore
Dim gitignoreFile
Set gitignoreFile = fso.CreateTextFile(basePath & "\.gitignore")
gitignoreFile.WriteLine("node_modules/")
gitignoreFile.WriteLine(".env")
gitignoreFile.WriteLine(".env.local")
gitignoreFile.WriteLine(".env.*.local")
gitignoreFile.WriteLine("*.log")
gitignoreFile.WriteLine("npm-debug.log*")
gitignoreFile.WriteLine("yarn-debug.log*")
gitignoreFile.WriteLine("yarn-error.log*")
gitignoreFile.WriteLine(".DS_Store")
gitignoreFile.WriteLine("dist/")
gitignoreFile.WriteLine("build/")
gitignoreFile.WriteLine(".vscode/")
gitignoreFile.WriteLine(".idea/")
gitignoreFile.Close()

' Create package.json
Dim packageFile
Set packageFile = fso.CreateTextFile(basePath & "\package.json")
packageFile.Write("{" & vbCrLf)
packageFile.Write("  ""name"": ""canteras-renacimiento-api""," & vbCrLf)
packageFile.Write("  ""version"": ""1.0.0""," & vbCrLf)
packageFile.Write("  ""description"": ""Admin API for Canteras Renacimiento""," & vbCrLf)
packageFile.Write("  ""main"": ""server.js""," & vbCrLf)
packageFile.Write("  ""scripts"": {" & vbCrLf)
packageFile.Write("    ""start"": ""node server.js""," & vbCrLf)
packageFile.Write("    ""dev"": ""nodemon server.js""" & vbCrLf)
packageFile.Write("  }," & vbCrLf)
packageFile.Write("  ""dependencies"": {" & vbCrLf)
packageFile.Write("    ""express"": ""^4.18.2""," & vbCrLf)
packageFile.Write("    ""mysql2"": ""^3.6.0""," & vbCrLf)
packageFile.Write("    ""jsonwebtoken"": ""^9.0.0""," & vbCrLf)
packageFile.Write("    ""bcryptjs"": ""^2.4.3""," & vbCrLf)
packageFile.Write("    ""dotenv"": ""^16.0.3""," & vbCrLf)
packageFile.Write("    ""cors"": ""^2.8.5""," & vbCrLf)
packageFile.Write("    ""multer"": ""^1.4.5-lts.1""," & vbCrLf)
packageFile.Write("    ""validator"": ""^13.9.0""" & vbCrLf)
packageFile.Write("  }," & vbCrLf)
packageFile.Write("  ""devDependencies"": {" & vbCrLf)
